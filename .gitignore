*.tmp
*.temp
/tmp/

# Downloaded tools and ISOs
assets/icons/tools/*.png
build/isos/*.iso
build/windows-tools/*

# Keep directory structure but ignore contents
!assets/icons/tools/.gitkeep
!build/isos/.gitkeep
!build/windows-tools/.gitkeep

# Logs
*.log
build.log

# Checksums (generated during build)
*.sha256
*.md5

